        % ax1 = subplot(8,1,1);imagesc(x_bins,1:size(V1_SUA{1},2),squeeze(V1_SUA{1}(this_event,:,:)))
        xlim([-1.5 1.5]);clim([0 1]);colormap(ax1,[1 1 1; 0.9668, 0.6152, 0.5859]);
        % colormap(flipud(gray));
