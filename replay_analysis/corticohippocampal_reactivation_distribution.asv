        Y = repmat([yl(1); yl(1); yl(2); yl(2)], 1, length(onsets));
        patch(X, Y, 'k', 'EdgeColor', 'none', 'FaceAlpha', 0.2);
        set(gca,"TickDir","out",'box','off','Color','none','FontSize',12)

