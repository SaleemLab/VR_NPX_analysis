                text(event_times(nearby_events_merged(i))-event_times(this_event),1,num2str(mean_V1_bias(event_id(nearby_events_merged((i)))), '%.2f'))
            else
                text(event_times(nearby_events_merged(i))-event_times(this_event),-1,num2str(mean_V1_bias(event_id(nearby_events_merged((i)))), '%.2f'))
            end
